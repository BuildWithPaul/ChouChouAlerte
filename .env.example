# ChouChouAlerte environment configuration
# Copy this to .env and fill in your values

# Required: SNCF API token (get from https://digital.sncf.com/startup/api)
SNCF_API_TOKEN=your_sncf_api_token_here

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-string

# Google OAuth (optional - leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional - leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Disruption check interval in seconds (default: 300 = 5 minutes)
DISRUPTION_CHECK_INTERVAL=300